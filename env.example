APP_BASE_URL=http://localhost:3000
OWNER_EMAIL=you@example.com
OWNER_NAME=Your Name
OWNER_TIME_ZONE=Asia/Shanghai
GOOGLE_CALENDAR_ID=primary

# Create these in Google Cloud Console as an OAuth 2.0 Web application.
# Authorized redirect URI:
# http://localhost:3000/api/admin/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: npm run gen:key. Keep this value private.
TOKEN_ENCRYPTION_KEY=

# Any long random string. Keep this value private. Required for /admin Google connect.
ADMIN_SECRET=

EVENT_TITLE=Intro Call
EVENT_LOCATION=Google Meet
EVENT_DURATION_MINUTES=30
BUFFER_MINUTES=10
SLOT_STEP_MINUTES=30
BOOKING_WINDOW_DAYS=14
MINIMUM_NOTICE_MINUTES=120
ENABLE_GOOGLE_MEET=true

# Optional JSON override. Luxon weekday numbers: Monday=1 ... Sunday=7.
# AVAILABILITY_JSON=[{"days":[1,2,3,4,5],"start":"10:00","end":"18:30"}]
